{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://example.com/policies/values.schema.json",
  "title": "policies Helm chart values",
  "description": "Editor-oriented schema for the policies chart (NetworkPolicy + Istio AuthorizationPolicy). Three independent sections: policies[], netpol[], authzpol[].",
  "type": "object",
  "additionalProperties": false,
  "propertyOrder": [
    "naming",
    "generic",
    "defaults",
    "policies",
    "netpol",
    "authzpol"
  ],
  "required": [
    "naming"
  ],
  "properties": {
    "naming": {
      "title": "Naming tags",
      "description": "Common tags for generating resource names by the convention {instanceTag}-{clusterTag}-{kindShort}-{projectTag}-{name}. kindShort: np | ap.",
      "$ref": "#/definitions/naming"
    },
    "generic": {
      "title": "Generic settings",
      "description": "Common labels/annotations applied to all chart resources.",
      "$ref": "#/definitions/generic",
      "ui:widget": "hidden"
    },
    "defaults": {
      "title": "Defaults",
      "description": "Default values for trust domain, namespace label key and port protocol.",
      "$ref": "#/definitions/defaults"
    },
    "policies": {
      "title": "Policies (NP + AP)",
      "description": "Universal policies. One block describes a source <-> target link; NetworkPolicy and AuthorizationPolicy are generated with auto-mirroring of egress into the target namespace.",
      "type": "array",
      "items": {
        "$ref": "#/definitions/policy"
      },
      "defaultSnippets": [
        {
          "label": "Policy (source <-> target)",
          "body": [
            {
              "name": "core",
              "enabled": true,
              "serviceAccount": "netbox",
              "selector": {
                "app.kubernetes.io/name": "netbox"
              },
              "ingress": [
                {
                  "from": [
                    {
                      "namespace": "netbox-ingress",
                      "selector": {
                        "app.kubernetes.io/name": "ingress-istio"
                      }
                    }
                  ],
                  "ports": [
                    {
                      "port": 8080
                    }
                  ]
                }
              ],
              "egress": [
                {
                  "to": [
                    {
                      "namespace": "netbox-postgresql",
                      "selector": {
                        "app.kubernetes.io/name": "postgresql"
                      }
                    }
                  ],
                  "ports": [
                    {
                      "port": 5432
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    "netpol": {
      "title": "NetworkPolicies",
      "description": "NetworkPolicy only, without AuthorizationPolicy and without mirrors. For L3/L4-only scenarios or ipBlock rules.",
      "type": "array",
      "items": {
        "$ref": "#/definitions/netpol"
      },
      "defaultSnippets": [
        {
          "label": "NetworkPolicy",
          "body": [
            {
              "name": "ing",
              "enabled": true,
              "selector": {
                "app.kubernetes.io/name": "ingress-istio"
              },
              "ingress": [
                {
                  "from": [
                    {
                      "ipBlock": {
                        "cidr": "0.0.0.0/0"
                      }
                    }
                  ],
                  "ports": [
                    {
                      "port": 443
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    "authzpol": {
      "title": "AuthorizationPolicies",
      "description": "AuthorizationPolicy only (Istio). For L7 rules (when, ports, custom principals) or when NP are described by another tool.",
      "type": "array",
      "items": {
        "$ref": "#/definitions/authzpol"
      },
      "defaultSnippets": [
        {
          "label": "AuthorizationPolicy",
          "body": [
            {
              "name": "gate",
              "enabled": true,
              "action": "ALLOW",
              "selector": {
                "app.kubernetes.io/name": "ingress-istio"
              },
              "rules": [
                {
                  "from": {
                    "ipBlocks": [
                      "0.0.0.0/0"
                    ]
                  },
                  "ports": [
                    {
                      "port": 443
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  },
  "definitions": {
    "k8sName": {
      "type": "string",
      "pattern": "^[a-z0-9]([a-z0-9-]*[a-z0-9])?$",
      "description": "Kubernetes DNS label: lower-case letters, digits and hyphens; no leading/trailing hyphen."
    },
    "shortToken": {
      "type": "string",
      "pattern": "^[a-z0-9]([a-z0-9-]*[a-z0-9])?$",
      "minLength": 2,
      "maxLength": 6,
      "description": "DNS token 2..6 characters: lower-case letters, digits and hyphens; no leading/trailing hyphen."
    },
    "port": {
      "type": "integer",
      "minimum": 1,
      "maximum": 65535
    },
    "stringMap": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "tplStringMap": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      },
      "description": "Map of string keys to string values (may use Helm tpl templating)."
    },
    "generic": {
      "type": "object",
      "additionalProperties": false,
      "propertyOrder": [
        "labels",
        "annotations"
      ],
      "properties": {
        "labels": {
          "title": "Common labels",
          "description": "Common labels for all chart resources. Result: metadata.labels.",
          "$ref": "#/definitions/tplStringMap"
        },
        "annotations": {
          "title": "Common annotations",
          "description": "Common annotations for all chart resources. Result: metadata.annotations.",
          "$ref": "#/definitions/tplStringMap"
        }
      }
    },
    "naming": {
      "type": "object",
      "additionalProperties": false,
      "propertyOrder": [
        "instanceTag",
        "clusterTag",
        "projectTag"
      ],
      "properties": {
        "instanceTag": {
          "title": "instanceTag",
          "description": "Instance tag (table 50). Required, lower-case DNS format.",
          "$ref": "#/definitions/k8sName"
        },
        "clusterTag": {
          "title": "clusterTag",
          "description": "Cluster tag (table 52). Required, lower-case DNS format.",
          "$ref": "#/definitions/k8sName"
        },
        "projectTag": {
          "title": "projectTag",
          "description": "Project tag. Required, 2..6 characters, lower-case DNS format.",
          "$ref": "#/definitions/shortToken"
        }
      },
      "required": [
        "instanceTag",
        "clusterTag",
        "projectTag"
      ]
    },
    "defaults": {
      "type": "object",
      "additionalProperties": false,
      "propertyOrder": [
        "trustDomain",
        "namespaceLabelKey",
        "protocol"
      ],
      "properties": {
        "trustDomain": {
          "title": "trustDomain",
          "description": "Istio trust domain for the principal: {trustDomain}/ns/{namespace}/sa/{serviceAccount}.",
          "type": "string",
          "default": "cluster.local"
        },
        "namespaceLabelKey": {
          "title": "namespaceLabelKey",
          "description": "Namespace label key for the NetworkPolicy namespaceSelector.",
          "type": "string",
          "default": "kubernetes.io/metadata.name"
        },
        "protocol": {
          "title": "protocol",
          "description": "Default protocol for NetworkPolicy ports.",
          "type": "string",
          "enum": [
            "TCP",
            "UDP",
            "SCTP"
          ],
          "default": "TCP"
        }
      }
    },
    "portEntry": {
      "type": "object",
      "additionalProperties": false,
      "propertyOrder": [
        "port",
        "protocol"
      ],
      "properties": {
        "port": {
          "title": "port",
          "description": "Destination port.",
          "$ref": "#/definitions/port"
        },
        "protocol": {
          "title": "protocol",
          "description": "Protocol of the port. Omitted -> defaults.protocol.",
          "type": "string",
          "enum": [
            "TCP",
            "UDP",
            "SCTP"
          ],
          "default": "TCP"
        }
      },
      "required": [
        "port"
      ]
    },
    "ipBlock": {
      "type": "object",
      "additionalProperties": false,
      "propertyOrder": [
        "cidr",
        "except"
      ],
      "properties": {
        "cidr": {
          "title": "cidr",
          "description": "CIDR block.",
          "type": "string"
        },
        "except": {
          "title": "except",
          "description": "Exclusions from the CIDR block.",
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "cidr"
      ]
    },
    "labelSelector": {
      "type": "object",
      "additionalProperties": false,
      "propertyOrder": [
        "matchLabels",
        "matchExpressions"
      ],
      "properties": {
        "matchLabels": {
          "title": "matchLabels",
          "$ref": "#/definitions/stringMap"
        },
        "matchExpressions": {
          "title": "matchExpressions",
          "type": "array",
          "items": {
            "$ref": "#/definitions/labelSelectorRequirement"
          }
        }
      }
    },
    "labelSelectorRequirement": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "key": {
          "type": "string"
        },
        "operator": {
          "type": "string",
          "enum": [
            "In",
            "NotIn",
            "Exists",
            "DoesNotExist"
          ]
        },
        "values": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "key",
        "operator"
      ]
    },
    "policyIngressPeer": {
      "type": "object",
      "additionalProperties": false,
      "description": "Ingress source: namespace+selector (+ optional serviceAccount for AP principals), ipBlock, or raw namespaceSelector/podSelector.",
      "propertyOrder": [
        "namespace",
        "selector",
        "serviceAccount",
        "ipBlock",
        "namespaceSelector",
        "podSelector"
      ],
      "properties": {
        "namespace": {
          "title": "namespace",
          "$ref": "#/definitions/k8sName"
        },
        "selector": {
          "title": "selector",
          "description": "Pod labels of the source.",
          "$ref": "#/definitions/stringMap"
        },
        "serviceAccount": {
          "title": "serviceAccount",
          "description": "Sender SA for the AP principal. Missing -> fallback to namespaces: [namespace].",
          "$ref": "#/definitions/k8sName"
        },
        "ipBlock": {
          "title": "ipBlock",
          "ui:widget": "hidden",
          "$ref": "#/definitions/ipBlock"
        },
        "namespaceSelector": {
          "title": "namespaceSelector",
          "ui:widget": "hidden",
          "$ref": "#/definitions/labelSelector"
        },
        "podSelector": {
          "title": "podSelector",
          "ui:widget": "hidden",
          "$ref": "#/definitions/labelSelector"
        }
      }
    },
    "policyEgressPeer": {
      "type": "object",
      "additionalProperties": false,
      "description": "Egress target: namespace+selector or ipBlock. serviceAccount is FORBIDDEN (owner SA is taken from policy.serviceAccount).",
      "propertyOrder": [
        "namespace",
        "selector",
        "ipBlock"
      ],
      "properties": {
        "namespace": {
          "title": "namespace",
          "$ref": "#/definitions/k8sName"
        },
        "selector": {
          "title": "selector",
          "description": "Pod labels of the target.",
          "$ref": "#/definitions/stringMap"
        },
        "ipBlock": {
          "title": "ipBlock",
          "ui:widget": "hidden",
          "$ref": "#/definitions/ipBlock"
        }
      }
    },
    "netpolPeer": {
      "type": "object",
      "additionalProperties": false,
      "description": "Peer for netpol: namespace+selector, ipBlock, or raw namespaceSelector/podSelector.",
      "propertyOrder": [
        "namespace",
        "selector",
        "ipBlock",
        "namespaceSelector",
        "podSelector"
      ],
      "properties": {
        "namespace": {
          "title": "namespace",
          "$ref": "#/definitions/k8sName"
        },
        "selector": {
          "title": "selector",
          "$ref": "#/definitions/stringMap"
        },
        "ipBlock": {
          "title": "ipBlock",
          "ui:widget": "hidden",
          "$ref": "#/definitions/ipBlock"
        },
        "namespaceSelector": {
          "title": "namespaceSelector",
          "ui:widget": "hidden",
          "$ref": "#/definitions/labelSelector"
        },
        "podSelector": {
          "title": "podSelector",
          "ui:widget": "hidden",
          "$ref": "#/definitions/labelSelector"
        }
      }
    },
    "policyIngressRule": {
      "type": "object",
      "additionalProperties": false,
      "propertyOrder": [
        "from",
        "ports"
      ],
      "properties": {
        "from": {
          "title": "from",
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/policyIngressPeer"
          }
        },
        "ports": {
          "title": "ports",
          "type": "array",
          "items": {
            "$ref": "#/definitions/portEntry"
          }
        }
      },
      "required": [
        "from"
      ]
    },
    "policyEgressRule": {
      "type": "object",
      "additionalProperties": false,
      "propertyOrder": [
        "to",
        "ports"
      ],
      "properties": {
        "to": {
          "title": "to",
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/policyEgressPeer"
          }
        },
        "ports": {
          "title": "ports",
          "type": "array",
          "items": {
            "$ref": "#/definitions/portEntry"
          }
        }
      },
      "required": [
        "to"
      ]
    },
    "netpolIngressRule": {
      "type": "object",
      "additionalProperties": false,
      "propertyOrder": [
        "from",
        "ports"
      ],
      "properties": {
        "from": {
          "title": "from",
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/netpolPeer"
          }
        },
        "ports": {
          "title": "ports",
          "type": "array",
          "items": {
            "$ref": "#/definitions/portEntry"
          }
        }
      },
      "required": [
        "from"
      ]
    },
    "netpolEgressRule": {
      "type": "object",
      "additionalProperties": false,
      "propertyOrder": [
        "to",
        "ports"
      ],
      "properties": {
        "to": {
          "title": "to",
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/netpolPeer"
          }
        },
        "ports": {
          "title": "ports",
          "type": "array",
          "items": {
            "$ref": "#/definitions/portEntry"
          }
        }
      },
      "required": [
        "to"
      ]
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "propertyOrder": [
        "name",
        "enabled",
        "serviceAccount",
        "selector",
        "ingress",
        "egress"
      ],
      "properties": {
        "name": {
          "title": "name",
          "description": "Policy name, 2..6 characters. {name} in the NP/AP names.",
          "$ref": "#/definitions/shortToken"
        },
        "enabled": {
          "title": "enabled",
          "description": "true = create; false = skip the whole entry.",
          "type": "boolean",
          "default": true
        },
        "serviceAccount": {
          "title": "serviceAccount",
          "description": "SA of the owner workload. Goes into the principal of mirror APs. Required when egress is present.",
          "$ref": "#/definitions/k8sName"
        },
        "selector": {
          "title": "selector",
          "description": "Pod selector of the owner workload (podSelector in NP, selector in AP).",
          "$ref": "#/definitions/stringMap"
        },
        "ingress": {
          "title": "ingress",
          "description": "Inbound traffic rules to the owner.",
          "type": "array",
          "items": {
            "$ref": "#/definitions/policyIngressRule"
          }
        },
        "egress": {
          "title": "egress",
          "description": "Outbound traffic rules of the owner (create NP+AP mirrors in the target ns).",
          "type": "array",
          "items": {
            "$ref": "#/definitions/policyEgressRule"
          }
        }
      },
      "required": [
        "name",
        "selector"
      ]
    },
    "netpol": {
      "type": "object",
      "additionalProperties": false,
      "propertyOrder": [
        "name",
        "enabled",
        "selector",
        "ingress",
        "egress"
      ],
      "properties": {
        "name": {
          "title": "name",
          "description": "Resource name, 2..6 characters. {name} in the NP name.",
          "$ref": "#/definitions/shortToken"
        },
        "enabled": {
          "title": "enabled",
          "type": "boolean",
          "default": true
        },
        "selector": {
          "title": "selector",
          "description": "podSelector. Empty/absent -> all pods in the ns.",
          "$ref": "#/definitions/stringMap"
        },
        "ingress": {
          "title": "ingress",
          "type": "array",
          "items": {
            "$ref": "#/definitions/netpolIngressRule"
          }
        },
        "egress": {
          "title": "egress",
          "type": "array",
          "items": {
            "$ref": "#/definitions/netpolEgressRule"
          }
        }
      },
      "required": [
        "name"
      ]
    },
    "authzpol": {
      "type": "object",
      "additionalProperties": false,
      "propertyOrder": [
        "name",
        "enabled",
        "action",
        "selector",
        "rules"
      ],
      "properties": {
        "name": {
          "title": "name",
          "description": "Resource name, 2..6 characters. {name} in the AP name.",
          "$ref": "#/definitions/shortToken"
        },
        "enabled": {
          "title": "enabled",
          "type": "boolean",
          "default": true
        },
        "action": {
          "title": "action",
          "description": "AuthorizationPolicy action.",
          "type": "string",
          "enum": [
            "ALLOW",
            "DENY",
            "AUDIT",
            "CUSTOM"
          ],
          "default": "ALLOW"
        },
        "selector": {
          "title": "selector",
          "description": "Whom the policy applies to. Omitted -> all workloads in the ns.",
          "$ref": "#/definitions/stringMap"
        },
        "rules": {
          "title": "rules",
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/authzRule"
          }
        }
      },
      "required": [
        "name",
        "rules"
      ]
    },
    "authzRule": {
      "type": "object",
      "additionalProperties": false,
      "propertyOrder": [
        "from",
        "ports",
        "when"
      ],
      "properties": {
        "from": {
          "title": "from",
          "description": "Source. Forms: serviceAccounts, principals, ipBlocks, namespaces.",
          "$ref": "#/definitions/authzSource"
        },
        "ports": {
          "title": "ports",
          "description": "Operation ports. Converted to strings.",
          "type": "array",
          "items": {
            "$ref": "#/definitions/portEntry"
          }
        },
        "when": {
          "title": "when",
          "$ref": "#/definitions/authzWhen"
        }
      }
    },
    "authzSource": {
      "type": "object",
      "additionalProperties": false,
      "description": "At least one of: serviceAccounts, principals, ipBlocks, namespaces.",
      "propertyOrder": [
        "serviceAccounts",
        "principals",
        "ipBlocks",
        "namespaces"
      ],
      "properties": {
        "serviceAccounts": {
          "title": "serviceAccounts",
          "description": "-> principals: {trustDomain}/ns/{namespace}/sa/{name}.",
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "namespace": {
                "$ref": "#/definitions/k8sName"
              },
              "name": {
                "$ref": "#/definitions/k8sName"
              }
            },
            "required": [
              "namespace",
              "name"
            ]
          }
        },
        "principals": {
          "title": "principals",
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "ipBlocks": {
          "title": "ipBlocks",
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "namespaces": {
          "title": "namespaces",
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "authzWhen": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "sourceNamespaces": {
          "title": "sourceNamespaces",
          "description": "-> when key source.namespace.",
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
