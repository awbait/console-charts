{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://example.com/egress-gateway/values.schema.json",
  "title": "egress-gateway Helm chart values",
  "description": "Editor-oriented schema for the egress-gateway chart (Istio waypoint egress + kube-ovn VpcEgressGateway). Все секции — списки.",
  "type": "object",
  "additionalProperties": false,
  "propertyOrder": [
    "naming",
    "generic",
    "egressGateway",
    "tlsRoutes",
    "vpcEgressGateway"
  ],
  "required": [
    "naming"
  ],
  "properties": {
    "naming": {
      "title": "Naming tags",
      "description": "Общие теги для генерации имён ресурсов по конвенции {instanceTag}-{clusterTag}-{kindShort}-{projectTag}-{name}.",
      "$ref": "#/definitions/naming"
    },
    "generic": {
      "title": "Generic settings",
      "description": "Общие labels/annotations, которые применяются ко всем ресурсам chart.",
      "ui:widget": "hidden",
      "$ref": "#/definitions/generic"
    },
    "egressGateway": {
      "title": "Egress Gateways",
      "description": "Список egress-шлюзов. Каждый элемент создаёт Gateway (Gateway API, TLS Passthrough) и одноимённый ConfigMap (kindShort egw). На каждый listener генерируется ServiceEntry.",
      "type": "array",
      "items": {
        "$ref": "#/definitions/egressGateway"
      },
      "defaultSnippets": [
        {
          "label": "Egress Gateway",
          "body": [
            {
              "name": "wp",
              "enabled": true,
              "listeners": [
                {
                  "name": "nx",
                  "hostname": "repository.solution.test",
                  "port": 443,
                  "protocol": "TLS",
                  "tlsMode": "Passthrough",
                  "addresses": [
                    "10.40.20.50"
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    "tlsRoutes": {
      "title": "TLS Routes",
      "description": "Список TLSRoute. parentRefs НЕ указываются — генерируются по совпадению hostnames с listener'ами egressGateway. На каждый совпавший Gateway создаётся отдельный TLSRoute.",
      "type": "array",
      "items": {
        "$ref": "#/definitions/tlsRoute"
      },
      "defaultSnippets": [
        {
          "label": "TLS Route",
          "body": [
            {
              "name": "rnx",
              "enabled": true,
              "hostnames": [
                "repository.solution.test"
              ],
              "rules": [
                {
                  "backendRefs": [
                    {
                      "name": "repository.solution.test",
                      "port": 443,
                      "weight": 100
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    "vpcEgressGateway": {
      "title": "VPC Egress Gateways",
      "description": "Список VpcEgressGateway (kube-ovn). vpc/externalSubnet/trafficPolicy/nodeSelector/policies захардкожены в шаблоне; здесь задаются name/externalIPs/replicas/selectors.",
      "type": "array",
      "items": {
        "$ref": "#/definitions/vpcEgressGateway"
      },
      "defaultSnippets": [
        {
          "label": "VPC Egress Gateway",
          "body": [
            {
              "name": "core",
              "externalIPs": [
                "10.193.101.10",
                "10.193.101.11"
              ]
            }
          ]
        }
      ]
    }
  },
  "definitions": {
    "k8sName": {
      "type": "string",
      "pattern": "^[a-z0-9]([a-z0-9-]*[a-z0-9])?$",
      "description": "Kubernetes DNS label: строчные буквы, цифры и дефисы; без дефиса в начале/конце."
    },
    "shortToken": {
      "type": "string",
      "pattern": "^[a-z0-9]([a-z0-9-]*[a-z0-9])?$",
      "minLength": 2,
      "maxLength": 6,
      "description": "DNS-токен 2..6 символов: строчные буквы, цифры и дефисы; без дефиса в начале/конце."
    },
    "port": {
      "type": "integer",
      "minimum": 1,
      "maximum": 65535
    },
    "stringMap": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "tplStringMap": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "naming": {
      "type": "object",
      "additionalProperties": false,
      "propertyOrder": [
        "instanceTag",
        "clusterTag",
        "projectTag"
      ],
      "properties": {
        "instanceTag": {
          "title": "instanceTag",
          "description": "Тег инстанса (таблица 50). Required, DNS-формат lower-case.",
          "$ref": "#/definitions/k8sName"
        },
        "clusterTag": {
          "title": "clusterTag",
          "description": "Тег кластера (таблица 52). Required, DNS-формат lower-case.",
          "$ref": "#/definitions/k8sName"
        },
        "projectTag": {
          "title": "projectTag",
          "description": "Тег проекта. Required, 2..6 символов, DNS-формат lower-case.",
          "$ref": "#/definitions/shortToken"
        }
      },
      "required": [
        "instanceTag",
        "clusterTag",
        "projectTag"
      ]
    },
    "generic": {
      "type": "object",
      "additionalProperties": false,
      "propertyOrder": [
        "labels",
        "annotations"
      ],
      "properties": {
        "labels": {
          "title": "Common labels",
          "description": "Общие labels для всех ресурсов chart. Результат: metadata.labels.",
          "$ref": "#/definitions/tplStringMap"
        },
        "annotations": {
          "title": "Common annotations",
          "description": "Общие annotations для всех ресурсов chart. Результат: metadata.annotations.",
          "$ref": "#/definitions/tplStringMap"
        }
      }
    },
    "egressGateway": {
      "type": "object",
      "additionalProperties": false,
      "propertyOrder": [
        "name",
        "enabled",
        "listeners"
      ],
      "properties": {
        "name": {
          "title": "name",
          "description": "Имя Gateway, 2..6 символов. {name} в имени Gateway/ConfigMap (kindShort egw).",
          "$ref": "#/definitions/shortToken"
        },
        "enabled": {
          "title": "enabled",
          "description": "true = создавать Gateway и его ConfigMap; false = пропустить.",
          "type": "boolean",
          "default": true
        },
        "listeners": {
          "title": "Listeners",
          "description": "Список listener'ов. Каждый описывает один внешний сервис: из него генерируется listener Gateway и ServiceEntry.",
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/egressListener"
          }
        }
      },
      "required": [
        "name",
        "listeners"
      ]
    },
    "egressListener": {
      "type": "object",
      "additionalProperties": false,
      "propertyOrder": [
        "name",
        "hostname",
        "port",
        "protocol",
        "tlsMode",
        "addresses",
        "exportTo",
        "location",
        "resolution"
      ],
      "properties": {
        "name": {
          "title": "name",
          "description": "Имя listener, 2..6 символов. {name} в имени ServiceEntry (kindShort egw) и имя listener'а Gateway.",
          "$ref": "#/definitions/shortToken"
        },
        "hostname": {
          "title": "hostname",
          "description": "hostname / SNI; идёт в ServiceEntry.hosts и сопоставляется с tlsRoutes.hostnames.",
          "type": "string",
          "minLength": 1
        },
        "port": {
          "title": "port",
          "description": "Порт listener и ServiceEntry.",
          "$ref": "#/definitions/port"
        },
        "protocol": {
          "title": "protocol",
          "description": "Протокол listener.",
          "type": "string",
          "default": "TLS"
        },
        "tlsMode": {
          "title": "tlsMode",
          "description": "Режим TLS listener.",
          "type": "string",
          "enum": [
            "Passthrough",
            "Terminate"
          ],
          "default": "Passthrough"
        },
        "addresses": {
          "title": "addresses",
          "description": "Статические IP внешнего сервиса. Заданы → resolution STATIC + endpoints в ServiceEntry, иначе → DNS.",
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "exportTo": {
          "title": "exportTo",
          "description": "Видимость ServiceEntry. По умолчанию [\".\"].",
          "ui:widget": "hidden",
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "location": {
          "title": "location",
          "description": "Положение относительно mesh. По умолчанию MESH_EXTERNAL.",
          "ui:widget": "hidden",
          "type": "string",
          "enum": [
            "MESH_EXTERNAL",
            "MESH_INTERNAL"
          ]
        },
        "resolution": {
          "title": "resolution",
          "description": "Override резолвинга ServiceEntry. По умолчанию STATIC при addresses, иначе DNS.",
          "ui:widget": "hidden",
          "type": "string",
          "enum": [
            "STATIC",
            "DNS",
            "DNS_ROUND_ROBIN",
            "NONE"
          ]
        }
      },
      "required": [
        "name",
        "hostname",
        "port"
      ]
    },
    "tlsRoute": {
      "type": "object",
      "additionalProperties": false,
      "propertyOrder": [
        "name",
        "enabled",
        "hostnames",
        "rules"
      ],
      "properties": {
        "name": {
          "title": "name",
          "description": "Имя Route, 2..6 символов. {name} в имени TLSRoute (с parentGatewayName).",
          "$ref": "#/definitions/shortToken"
        },
        "enabled": {
          "title": "enabled",
          "description": "true = создавать TLSRoute; false = пропустить.",
          "type": "boolean",
          "default": true
        },
        "hostnames": {
          "title": "hostnames",
          "description": "hostname / SNI маршрута. Должны совпадать с hostname listener'а egressGateway (для генерации parentRefs).",
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "rules": {
          "title": "rules",
          "description": "Правила TLSRoute.",
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/tlsRouteRule"
          }
        }
      },
      "required": [
        "name",
        "hostnames",
        "rules"
      ]
    },
    "tlsRouteRule": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "backendRefs": {
          "title": "backendRefs",
          "description": "Backend-сервисы. name совпадает с host из ServiceEntry (= hostname).",
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/tlsBackendRef"
          }
        }
      },
      "required": [
        "backendRefs"
      ]
    },
    "tlsBackendRef": {
      "type": "object",
      "additionalProperties": false,
      "propertyOrder": [
        "name",
        "port",
        "weight"
      ],
      "properties": {
        "name": {
          "title": "name",
          "description": "Host backend (= hostname из ServiceEntry).",
          "type": "string",
          "minLength": 1
        },
        "port": {
          "title": "port",
          "$ref": "#/definitions/port"
        },
        "weight": {
          "title": "weight",
          "description": "Вес backend при балансировке.",
          "type": "integer",
          "minimum": 0,
          "default": 100
        }
      },
      "required": [
        "name",
        "port"
      ]
    },
    "vpcEgressGateway": {
      "type": "object",
      "additionalProperties": false,
      "propertyOrder": [
        "name",
        "enabled",
        "externalIPs",
        "replicas",
        "selectors"
      ],
      "properties": {
        "name": {
          "title": "name",
          "description": "Имя ресурса, 2..6 символов. {name} в имени VpcEgressGateway (kindShort veg).",
          "$ref": "#/definitions/shortToken"
        },
        "enabled": {
          "title": "enabled",
          "description": "true = создавать VpcEgressGateway; false = пропустить.",
          "type": "boolean",
          "default": true
        },
        "externalIPs": {
          "title": "externalIPs",
          "description": "Внешние IP-адреса egress. Обязательно.",
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "replicas": {
          "title": "replicas",
          "description": "Число реплик. По умолчанию = числу externalIPs.",
          "type": "integer",
          "minimum": 1
        },
        "selectors": {
          "title": "selectors",
          "description": "namespaceSelectors[] и podSelectors[] (raw kube-ovn формат).",
          "type": "object",
          "additionalProperties": false,
          "propertyOrder": [
            "namespaceSelectors",
            "podSelectors"
          ],
          "properties": {
            "namespaceSelectors": {
              "title": "namespaceSelectors",
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": true
              }
            },
            "podSelectors": {
              "title": "podSelectors",
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": true
              }
            }
          }
        }
      },
      "required": [
        "name",
        "externalIPs"
      ]
    }
  }
}
