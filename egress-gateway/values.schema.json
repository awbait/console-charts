{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://example.com/egress-gateway/values.schema.json",
  "title": "egress-gateway Helm chart values",
  "description": "Editor-oriented schema for the egress-gateway chart (Istio waypoint egress + kube-ovn VpcEgressGateway). All sections are lists.",
  "type": "object",
  "additionalProperties": false,
  "propertyOrder": [
    "naming",
    "generic",
    "egressGateway",
    "tlsRoutes",
    "vpcEgressGateway"
  ],
  "required": [
    "naming"
  ],
  "properties": {
    "naming": {
      "title": "Naming tags",
      "description": "Common tags for generating resource names by the convention {instanceTag}-{clusterTag}-{kindShort}-{projectTag}-{name}.",
      "$ref": "#/definitions/naming"
    },
    "generic": {
      "title": "Generic settings",
      "description": "Common labels/annotations applied to all chart resources.",
      "ui:widget": "hidden",
      "$ref": "#/definitions/generic"
    },
    "egressGateway": {
      "title": "Egress Gateways",
      "description": "List of egress gateways. Each item creates a Gateway (Gateway API, TLS Passthrough) and a same-named ConfigMap (kindShort egw). A ServiceEntry is generated per listener.",
      "type": "array",
      "items": {
        "$ref": "#/definitions/egressGateway"
      },
      "defaultSnippets": [
        {
          "label": "Egress Gateway",
          "body": [
            {
              "name": "wp",
              "enabled": true,
              "listeners": [
                {
                  "name": "nx",
                  "hostname": "repository.solution.test",
                  "port": 443,
                  "protocol": "TLS",
                  "tlsMode": "Passthrough",
                  "addresses": [
                    "10.40.20.50"
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    "tlsRoutes": {
      "title": "TLS Routes",
      "description": "List of TLSRoute. parentRefs are NOT set - they are generated by matching hostnames with egressGateway listeners. A separate TLSRoute is created for each matched Gateway.",
      "type": "array",
      "items": {
        "$ref": "#/definitions/tlsRoute"
      },
      "defaultSnippets": [
        {
          "label": "TLS Route",
          "body": [
            {
              "name": "rnx",
              "enabled": true,
              "hostnames": [
                "repository.solution.test"
              ],
              "rules": [
                {
                  "backendRefs": [
                    {
                      "name": "repository.solution.test",
                      "port": 443,
                      "weight": 100
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    "vpcEgressGateway": {
      "title": "VPC Egress Gateways",
      "description": "List of VpcEgressGateway (kube-ovn). vpc/externalSubnet/trafficPolicy/nodeSelector/policies are hardcoded in the template; name/externalIPs/replicas/selectors are set here.",
      "type": "array",
      "items": {
        "$ref": "#/definitions/vpcEgressGateway"
      },
      "defaultSnippets": [
        {
          "label": "VPC Egress Gateway",
          "body": [
            {
              "name": "core",
              "externalIPs": [
                "10.193.101.10",
                "10.193.101.11"
              ]
            }
          ]
        }
      ]
    }
  },
  "definitions": {
    "k8sName": {
      "type": "string",
      "pattern": "^[a-z0-9]([a-z0-9-]*[a-z0-9])?$",
      "description": "Kubernetes DNS label: lower-case letters, digits and hyphens; no leading/trailing hyphen."
    },
    "shortToken": {
      "type": "string",
      "pattern": "^[a-z0-9]([a-z0-9-]*[a-z0-9])?$",
      "minLength": 2,
      "maxLength": 6,
      "description": "DNS token, 2..6 characters: lower-case letters, digits and hyphens; no leading/trailing hyphen."
    },
    "port": {
      "type": "integer",
      "minimum": 1,
      "maximum": 65535
    },
    "stringMap": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "tplStringMap": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "naming": {
      "type": "object",
      "additionalProperties": false,
      "propertyOrder": [
        "instanceTag",
        "clusterTag",
        "projectTag"
      ],
      "properties": {
        "instanceTag": {
          "title": "instanceTag",
          "description": "Instance tag (table 50). Required, lower-case DNS format.",
          "$ref": "#/definitions/k8sName"
        },
        "clusterTag": {
          "title": "clusterTag",
          "description": "Cluster tag (table 52). Required, lower-case DNS format.",
          "$ref": "#/definitions/k8sName"
        },
        "projectTag": {
          "title": "projectTag",
          "description": "Project tag. Required, 2..6 characters, lower-case DNS format.",
          "$ref": "#/definitions/shortToken"
        }
      },
      "required": [
        "instanceTag",
        "clusterTag",
        "projectTag"
      ]
    },
    "generic": {
      "type": "object",
      "additionalProperties": false,
      "propertyOrder": [
        "labels",
        "annotations"
      ],
      "properties": {
        "labels": {
          "title": "Common labels",
          "description": "Common labels for all chart resources. Result: metadata.labels.",
          "$ref": "#/definitions/tplStringMap"
        },
        "annotations": {
          "title": "Common annotations",
          "description": "Common annotations for all chart resources. Result: metadata.annotations.",
          "$ref": "#/definitions/tplStringMap"
        }
      }
    },
    "egressGateway": {
      "type": "object",
      "additionalProperties": false,
      "propertyOrder": [
        "name",
        "enabled",
        "listeners"
      ],
      "properties": {
        "name": {
          "title": "name",
          "description": "Gateway name, 2..6 characters. {name} in the Gateway/ConfigMap name (kindShort egw).",
          "$ref": "#/definitions/shortToken"
        },
        "enabled": {
          "title": "enabled",
          "description": "true = create the Gateway and its ConfigMap; false = skip.",
          "type": "boolean",
          "default": true
        },
        "listeners": {
          "title": "Listeners",
          "description": "List of listeners. Each describes one external service: it generates a Gateway listener and a ServiceEntry.",
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/egressListener"
          }
        }
      },
      "required": [
        "name",
        "listeners"
      ]
    },
    "egressListener": {
      "type": "object",
      "additionalProperties": false,
      "propertyOrder": [
        "name",
        "hostname",
        "port",
        "protocol",
        "tlsMode",
        "addresses",
        "exportTo",
        "location",
        "resolution"
      ],
      "properties": {
        "name": {
          "title": "name",
          "description": "Listener name, 2..6 characters. {name} in the ServiceEntry name (kindShort egw) and the Gateway listener name.",
          "$ref": "#/definitions/shortToken"
        },
        "hostname": {
          "title": "hostname",
          "description": "hostname / SNI; goes into ServiceEntry.hosts and is matched against tlsRoutes.hostnames.",
          "type": "string",
          "minLength": 1
        },
        "port": {
          "title": "port",
          "description": "Listener and ServiceEntry port.",
          "$ref": "#/definitions/port"
        },
        "protocol": {
          "title": "protocol",
          "description": "Listener protocol.",
          "type": "string",
          "default": "TLS"
        },
        "tlsMode": {
          "title": "tlsMode",
          "description": "Listener TLS mode.",
          "type": "string",
          "enum": [
            "Passthrough",
            "Terminate"
          ],
          "default": "Passthrough"
        },
        "addresses": {
          "title": "addresses",
          "description": "Static IPs of the external service. Set -> resolution STATIC + endpoints in ServiceEntry, otherwise -> DNS.",
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "exportTo": {
          "title": "exportTo",
          "description": "ServiceEntry visibility. Defaults to [\".\"].",
          "ui:widget": "hidden",
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "location": {
          "title": "location",
          "description": "Position relative to the mesh. Defaults to MESH_EXTERNAL.",
          "ui:widget": "hidden",
          "type": "string",
          "enum": [
            "MESH_EXTERNAL",
            "MESH_INTERNAL"
          ]
        },
        "resolution": {
          "title": "resolution",
          "description": "ServiceEntry resolution override. Defaults to STATIC when addresses are set, otherwise DNS.",
          "ui:widget": "hidden",
          "type": "string",
          "enum": [
            "STATIC",
            "DNS",
            "DNS_ROUND_ROBIN",
            "NONE"
          ]
        }
      },
      "required": [
        "name",
        "hostname",
        "port"
      ]
    },
    "tlsRoute": {
      "type": "object",
      "additionalProperties": false,
      "propertyOrder": [
        "name",
        "enabled",
        "hostnames",
        "rules"
      ],
      "properties": {
        "name": {
          "title": "name",
          "description": "Route name, 2..6 characters. {name} in the TLSRoute name (with parentGatewayName).",
          "$ref": "#/definitions/shortToken"
        },
        "enabled": {
          "title": "enabled",
          "description": "true = create the TLSRoute; false = skip.",
          "type": "boolean",
          "default": true
        },
        "hostnames": {
          "title": "hostnames",
          "description": "Route hostname / SNI. Must match an egressGateway listener hostname (to generate parentRefs).",
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "rules": {
          "title": "rules",
          "description": "TLSRoute rules.",
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/tlsRouteRule"
          }
        }
      },
      "required": [
        "name",
        "hostnames",
        "rules"
      ]
    },
    "tlsRouteRule": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "backendRefs": {
          "title": "backendRefs",
          "description": "Backend services. name matches the ServiceEntry host (= hostname).",
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/tlsBackendRef"
          }
        }
      },
      "required": [
        "backendRefs"
      ]
    },
    "tlsBackendRef": {
      "type": "object",
      "additionalProperties": false,
      "propertyOrder": [
        "name",
        "port",
        "weight"
      ],
      "properties": {
        "name": {
          "title": "name",
          "description": "Backend host (= ServiceEntry hostname).",
          "type": "string",
          "minLength": 1
        },
        "port": {
          "title": "port",
          "$ref": "#/definitions/port"
        },
        "weight": {
          "title": "weight",
          "description": "Backend weight for load balancing.",
          "type": "integer",
          "minimum": 0,
          "default": 100
        }
      },
      "required": [
        "name",
        "port"
      ]
    },
    "vpcEgressGateway": {
      "type": "object",
      "additionalProperties": false,
      "propertyOrder": [
        "name",
        "enabled",
        "externalIPs",
        "replicas",
        "selectors"
      ],
      "properties": {
        "name": {
          "title": "name",
          "description": "Resource name, 2..6 characters. {name} in the VpcEgressGateway name (kindShort veg).",
          "$ref": "#/definitions/shortToken"
        },
        "enabled": {
          "title": "enabled",
          "description": "true = create the VpcEgressGateway; false = skip.",
          "type": "boolean",
          "default": true
        },
        "externalIPs": {
          "title": "externalIPs",
          "description": "External egress IP addresses. Required.",
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "replicas": {
          "title": "replicas",
          "description": "Number of replicas. Defaults to the number of externalIPs.",
          "type": "integer",
          "minimum": 1
        },
        "selectors": {
          "title": "selectors",
          "description": "namespaceSelectors[] and podSelectors[] (raw kube-ovn format).",
          "type": "object",
          "additionalProperties": false,
          "propertyOrder": [
            "namespaceSelectors",
            "podSelectors"
          ],
          "properties": {
            "namespaceSelectors": {
              "title": "namespaceSelectors",
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": true
              }
            },
            "podSelectors": {
              "title": "podSelectors",
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": true
              }
            }
          }
        }
      },
      "required": [
        "name",
        "externalIPs"
      ]
    }
  }
}
